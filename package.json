{
  "name": "kitsunarr",
  "description": " Adds a one-click \"Add to Sonarr\" button to AniList/AniChart pages. The easiest way to get anime from AniList/AniChart to Sonarr.",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "lint": "eslint src",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ci": "vitest run --coverage",
    "test:contract": "tsx scripts/test-contract.ts",
    "test:e2e": "npm run build && npm run build:firefox && playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@mswjs/http-middleware": "^0.10.0",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "^4.1.10",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@wxt-dev/auto-icons": "^1.0.2",
    "@wxt-dev/module-react": "^1.1.3",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.5.2",
    "express": "^5.1.0",
    "fake-indexeddb": "^6.2.2",
    "globals": "^16.2.0",
    "jsdom": "^25.0.1",
    "msw": "^2.6.6",
    "tailwindcss": "^4.1.10",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.4",
    "wxt": "^0.20.11"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/query-persist-client-core": "^5.91.4",
    "@tanstack/react-query": "5.90.x",
    "@tanstack/react-query-persist-client": "^5.90.7",
    "@webext-core/job-scheduler": "^1.0.0",
    "@webext-core/messaging": "^2.3.0",
    "@webext-core/proxy-service": "^1.2.1",
    "@wxt-dev/storage": "^1.1.1",
    "@wxt-dev/webextension-polyfill": "^1.0.0",
    "idb": "^8.0.3",
    "p-queue": "^8.0.1",
    "p-retry": "^7.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  }
}
